# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# --- AWS credentials (contact form / SES) ---
# Read automatically by the AWS SDK's default credential chain.
# Leave these UNSET in production if the EC2 instance has an IAM role
# with `ses:SendEmail` — the SDK will use the role instead.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Contact form config (consumed via runtimeConfig) ---
# AWS region your SES identities live in.
SES_REGION=ap-southeast-2
# Sender address — must be a verified SES identity.
CONTACT_FROM_EMAIL=
# Recipient — where contact form submissions are delivered.
CONTACT_TO_EMAIL=
