{
  // https://nuxt.com/docs/guide/concepts/typescript
  //
  // Required so tsconfck (Vite/esbuild) resolving files under observe/ stops
  // here and doesn't walk up to the parent portfolio tsconfig.json, whose
  // `extends: ./.nuxt/tsconfig.json` can't resolve in CI (the portfolio root is
  // never installed/prepared by the observe workflow). observe/.nuxt is
  // generated by `nuxt prepare` (postinstall) / `nuxt build`.
  "extends": "./.nuxt/tsconfig.json"
}
