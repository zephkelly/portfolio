# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# In CI these same keys are supplied via the OBSERVE_ENV_FILE GitHub secret.

# Port the Nitro server listens on (portfolio uses 8000; observe uses 8004).
PORT=8004

# nuxt-auth-utils cookie session secret. Must be >= 32 characters.
# Generate: openssl rand -base64 48
NUXT_SESSION_PASSWORD=

# Dashboard bootstrap admin password (login user is `admin`).
# Referenced by observe.auth.users[0].passwordEnv in nuxt.config.ts.
NUXT_OBSERVE_ADMIN_PASSWORD=

# --- External JWT verification (optional) ---------------------------------
# Lets an `Authorization: Bearer <token>` authenticate any /api/observe/* request
# statelessly (no cookie). Requires an `auth.jwt: { enabled: true, algorithms: [...] }`
# block in nuxt.config.ts for these to take effect (the env var only overrides a
# secret that the config already declares).
#
# HS256 (shared secret) — the simplest option when this app both signs and verifies.
# Generate: openssl rand -base64 48
NUXT_OBSERVE_AUTH_JWT_SECRET=
#
# RS256 (asymmetric) — use instead of a secret when an external issuer signs tokens.
# Paste the PEM SPKI public key (or set observe.auth.jwt.jwksUri in config instead).
# NUXT_OBSERVE_AUTH_JWT_PUBLIC_KEY=
