# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# In CI these same keys are supplied via the OBSERVE_ENV_FILE GitHub secret.

# Port the Nitro server listens on (portfolio uses 8000; observe uses 8001).
PORT=8001

# nuxt-auth-utils cookie session secret. Must be >= 32 characters.
# Generate: openssl rand -base64 48
NUXT_SESSION_PASSWORD=

# Dashboard bootstrap admin password (login user is `admin`).
# Referenced by observe.auth.users[0].passwordEnv in nuxt.config.ts.
NUXT_OBSERVE_ADMIN_PASSWORD=
